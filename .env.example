# Security
API_KEY=your_api_key_here
ALLOWED_ORIGINS="*"

QDRANT_HOST=http://your_qdrant_host_ip
QDRANT_PORT=6333
QDRANT_TEXT_COLLECTION=your_collection_name
QDRANT_PIPELINE_EKSTRACTION=your_pipeline_collection

LANGSMITH_TRACING="true"
LANGSMITH_API_KEY=your_langsmith_api_key

# PILIH PROVIDER LLM: huggingface | bedrock | runpod | kaggle_ollama | kaggle_vllm | tim2_vllm | kaggle_llamacp
LLM_PROVIDER=huggingface

# 0. Konfigurasi Hugging Face
HF_TOKEN=your_huggingface_token
HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
MAX_TOKEN=4500
MAX_RAG_TOKEN=5000

# 1. Konfigurasi Bedrock
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
BEDROCK_ENDPOINT_URL=https://bedrock-runtime.us-east-1.amazonaws.com
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# 2. Konfigurasi RunPod (OpenAI Compatible)
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_ENDPOINT_URL=https://api.runpod.io/v1/your_endpoint/v1
RUNPOD_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct

# 3. Konfigurasi Kaggle / Ngrok
NGROK_KAGGLE_OLLAMA=https://your_ngrok_url.ngrok-free.dev
KAGGLE_OLLAMA_MODEL_ID=qwen3.5:9b
NGROK_KAGGLE_VLLM=https://your_ngrok_url.ngrok-free.dev/v1
KAGGLE_VLLM_MODEL_ID=your_model_id

NGROK_KAGGLE_LLAMACPP=https://your_ngrok_url.ngrok-free.dev
KAGGLE_LLAMACPP_MODEL_ID=unsloth/Qwen3.5-9B-GGUF:Q8_0

# 4. RAG Models Configuration
DENSE_MODEL=BAAI/bge-m3
SPARSE_MODEL=naver/splade-cocondenser-ensembledistil
RERANKER_MODEL=BAAI/bge-reranker-base
OLLAMA_HOST=https://your_ollama_host.ngrok-free.dev
OLLAMA_MODEL=qwen2.5vl:7b

TIM2_VLLM_ENDPOINT=https://your_vllm_endpoint.trycloudflare.com/v1
TIM2_MODEL_ID=your_tim2_model_id
TIM2_TEMPERATURE=0.2

# ==========================================
# KONFIGURASI LLM KHUSUS EVALUATOR (Opsional)
# ==========================================
EVAL_LLM_PROVIDER=huggingface
EVAL_HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
# EVAL_OPENAI_API_KEY=your_openai_api_key
# EVAL_OPENAI_MODEL_ID=gpt-4o-mini

SEARCH_MODE=hybrid
MODEL_API_URL=https://your_model_api_url.trycloudflare.com
