# API_KEY=<your_api_key>  # Uncomment saat production
ALLOWED_ORIGINS="*"

# ── Message Broker (Redis + Celery) ─────────────────────────────────────────
# Untuk dev lokal: pastikan Redis jalan (docker run -p 6379:6379 redis:7-alpine)
# Untuk production (docker-compose): gunakan redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
CELERY_CONCURRENCY=2

# ── Concurrency limiter untuk /konten/generate ───────────────────────────────
# Naikkan jika LLM provider kuat, turunkan jika sering timeout.
MAX_CONCURRENT_GENERATION=10

QDRANT_HOST=<your_qdrant_url>
QDRANT_HOSTS=<your_qdrant_ip>
QDRANT_PORT=6333

QDRANT_TEXT_COLLECTION=<your_text_collection_name>
QDRANT_PIPELINE_EKSTRACTION=<your_extraction_collection_name>

LANGSMITH_TRACING="true"
LANGSMITH_API_KEY=<your_langsmith_api_key>

# PILIH PROVIDER LLM: huggingface | bedrock | runpod | kaggle_ollama | kaggle_vllm | tim2_vllm | kaggle_llamacp
LLM_PROVIDER=tim2_vllm

# 0. Konfigurasi Hugging Face
HF_TOKEN=<your_hf_token>
HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
MAX_TOKEN=3000
MAX_RAG_TOKEN=

# 1. Konfigurasi Bedrock
AWS_ACCESS_KEY_ID=<your_aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_access_key>
BEDROCK_ENDPOINT_URL=<your_bedrock_endpoint_url>
BEDROCK_REGION=us-east-1  # Sesuaikan dengan region dari dia
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0 # Sesuaikan model ID yang dipakai

# 2. Konfigurasi RunPod (OpenAI Compatible)
RUNPOD_API_KEY=<your_runpod_api_key>
RUNPOD_ENDPOINT_URL=https://api.runpod.io/v1/<your_endpoint>/v1
RUNPOD_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct

# 3. Konfigurasi Kaggle / Ngrok
NGROK_KAGGLE_OLLAMA=<your_ngrok_url>
KAGGLE_OLLAMA_MODEL_ID=qwen3.5:9b
NGROK_KAGGLE_VLLM=<your_ngrok_vllm_url>
KAGGLE_VLLM_MODEL_ID=AITF-SR-02/ub-sr-02-qwen3.5-9b-base-5k-CPT-SFT-v2

NGROK_KAGGLE_LLAMACPP=<your_ngrok_llamacpp_url>
KAGGLE_LLAMACPP_MODEL_ID=unsloth/Qwen3.5-9B-GGUF:Q8_0

# 4. RAG Models Configuration
QDRANT_TEXT_COLLECTION=<your_text_collection_name>
DENSE_MODEL=BAAI/bge-m3
SPARSE_MODEL=naver/splade-cocondenser-ensembledistil
RERANKER_MODEL=BAAI/bge-reranker-base
OLLAMA_HOST=<your_ngrok_ollama_host_url>
OLLAMA_MODEL=qwen2.5vl:7b

TIM2_VLLM_ENDPOINT=<your_cloudflare_or_ngrok_url>/v1
TIM2_MODEL_ID=ub-sr-all
TIM2_TEMPERATURE=0.2

# ==========================================
# KONFIGURASI LLM KHUSUS EVALUATOR (Opsional)
# ==========================================
# Jika tidak di-set, Evaluator akan memakai LLM utama.
# Pilihan: huggingface | openai | bedrock | vllm
# EVAL_LLM_PROVIDER=
# EVAL_HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
# EVAL_VLLM_ENDPOINT=<your_eval_vllm_endpoint_url>/v1
# EVAL_VLLM_MODEL_ID=ub-sr-all
# EVAL_OPENAI_API_KEY=<your_openai_api_key>
# EVAL_OPENAI_MODEL_ID=gpt-4o-mini

# EVAL_LLM_PROVIDER=huggingface
# EVAL_LLM_PROVIDER=kaggle_llamacpp
# EVAL_KAGGLE_LLAMACPP_MODEL_ID=unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q4_K_M
# EVAL_NGROK_KAGGLE_LLAMACPP=<your_eval_ngrok_llamacpp_url>
# EVAL_BEDROCK_MODEL_ID=google.gemma-3-4b-it
# EVAL_BEDROCK_REGION=us-east-1
# EVAL_BEDROCK_ENDPOINT_URL=<your_eval_bedrock_endpoint_url>
# EVAL_AWS_ACCESS_KEY_ID=<your_eval_aws_access_key_id>
# EVAL_AWS_SECRET_ACCESS_KEY=<your_eval_aws_secret_access_key>

# EVAL_LLM_PROVIDER=runpod
# EVAL_RUNPOD_ENDPOINT_URL=https://api.runpod.ai/v2/<your_endpoint>/openai/v1
# EVAL_RUNPOD_API_KEY=<your_eval_runpod_api_key>
# EVAL_RUNPOD_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct

SEARCH_MODE=hybrid
MODEL_API_URL=<your_model_api_url>
