# API_KEY=<your_api_key_here>  # Uncomment saat production
# Pisahkan domain dengan koma (mis. https://app.sekolah.id,https://admin.sekolah.id)
ALLOWED_ORIGINS="*"

# ── Keamanan & Message Broker (Redis + Celery + Flower) ─────────────────────
# Untuk dev lokal: pastikan Redis jalan (docker run -p 6379:6379 redis:7-alpine)
# Untuk production (docker-compose): gunakan redis://:password@redis:6379/0
REDIS_PASSWORD=<your_redis_password>
REDIS_URL="redis://:<your_redis_password>@localhost:6379/0"

CELERY_AVAILABLE=True
CELERY_CONCURRENCY=4   # Jumlah task Celery default yang berjalan paralel (default: 4)
GUNICORN_WORKERS=2     # Jumlah Uvicorn worker untuk API (default: 2)

# Otentikasi Dashboard Monitoring Flower (http://localhost:5555)
FLOWER_USER="admin"
FLOWER_PASSWORD=<your_flower_password>

# ── Rate Limiting & Concurrency (SlowAPI) ───────────────────────────────────
# Batas kuota request HTTP per menit per IP
RATE_LIMIT_GENERATE="10/minute"
RATE_LIMIT_UPLOAD="10/minute"
MAX_CONCURRENT_GENERATION=10

QDRANT_HOST=<your_qdrant_url>
QDRANT_HOSTS=<your_qdrant_ip>
QDRANT_PORT=6333
QDRANT_API_KEY=<your_qdrant_api_key>

QDRANT_TEXT_COLLECTION=<your_text_collection>
QDRANT_PIPELINE_EKSTRACTION=<your_pipeline_collection>

LANGSMITH_TRACING="true"
LANGSMITH_API_KEY=<your_langsmith_api_key>
# Nama project di LangSmith. Default: "beta-agentic".
# Ganti sesuai environment (misal: "beta-agentic-staging", "beta-agentic-prod")
LANGSMITH_PROJECT=beta-agentic
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

CHAT_CHUNK_SIZE=angka

# PILIH PROVIDER LLM: huggingface | bedrock | runpod | kaggle_ollama | kaggle_vllm | tim2_vllm | kaggle_llamacp
LLM_PROVIDER=tim2_vllm

# 0. Konfigurasi Hugging Face
HF_TOKEN=<your_hf_token>
HF_MODEL_ID=<your_hf_model_id>
MAX_TOKEN=3000
MAX_RAG_TOKEN=

# 1. Konfigurasi Bedrock
AWS_ACCESS_KEY_ID=<your_aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_access_key>
BEDROCK_ENDPOINT_URL=<your_bedrock_endpoint_url>
BEDROCK_REGION=<your_bedrock_region>
BEDROCK_MODEL_ID=<your_bedrock_model_id>

# 2. Konfigurasi RunPod (OpenAI Compatible)
RUNPOD_API_KEY=<your_runpod_api_key>
RUNPOD_ENDPOINT_URL=<your_runpod_endpoint_url>
RUNPOD_MODEL_ID=<your_runpod_model_id>

# 3. Konfigurasi Kaggle / Ngrok
NGROK_KAGGLE_OLLAMA=<your_ngrok_kaggle_ollama_url>
KAGGLE_OLLAMA_MODEL_ID=<your_kaggle_ollama_model_id>
NGROK_KAGGLE_VLLM=<your_ngrok_kaggle_vllm_url>
KAGGLE_VLLM_MODEL_ID=<your_kaggle_vllm_model_id>

NGROK_KAGGLE_LLAMACPP=<your_ngrok_kaggle_llamacpp_url>
KAGGLE_LLAMACPP_MODEL_ID=<your_kaggle_llamacpp_model_id>

# 4. RAG Models Configuration
DENSE_MODEL=<your_dense_model_id>
SPARSE_MODEL=<your_sparse_model_id>
RERANKER_MODEL=<your_reranker_model_id>
OLLAMA_HOST=<your_ollama_host_url>
OLLAMA_MODEL=<your_ollama_model_id>

# Format single host (1 GPU server):
# Wajib sertakan /v1 di akhir URL karena vLLM pakai OpenAI-compatible API
TIM2_VLLM_ENDPOINT=http://<ip_gpu>:<port>/v1

# Format multi-host — pisahkan dengan titik koma (;) untuk auto-routing:
# Sistem akan otomatis memilih host yang paling longgar via GET /metrics
# (kode otomatis strip /v1 saat ping /metrics, jadi tidak perlu khawatir)
# TIM2_VLLM_ENDPOINT=http://<ip_gpu1>:<port>/v1;http://<ip_gpu2>:<port>/v1

TIM2_MODEL_ID=<your_tim2_model_id>
TIM2_TEMPERATURE=0.2

# ==========================================
# KONFIGURASI LLM KHUSUS EVALUATOR (Opsional)
# ==========================================
# Jika tidak di-set, Evaluator akan memakai LLM utama.
# Pilihan: huggingface | openai | bedrock | vllm
# EVAL_LLM_PROVIDER=
# EVAL_HF_MODEL_ID=<your_eval_hf_model_id>
# EVAL_VLLM_ENDPOINT=<your_eval_vllm_endpoint_url>
# EVAL_VLLM_MODEL_ID=<your_eval_vllm_model_id>
# EVAL_OPENAI_API_KEY=<your_eval_openai_api_key>
# EVAL_OPENAI_MODEL_ID=<your_eval_openai_model_id>

# EVAL_LLM_PROVIDER=huggingface
# EVAL_LLM_PROVIDER=kaggle_llamacpp
# EVAL_KAGGLE_LLAMACPP_MODEL_ID=<your_eval_kaggle_llamacpp_model_id>
# EVAL_NGROK_KAGGLE_LLAMACPP=<your_eval_ngrok_kaggle_llamacpp_url>
# EVAL_BEDROCK_MODEL_ID=<your_eval_bedrock_model_id>
# EVAL_BEDROCK_REGION=<your_eval_bedrock_region>
# EVAL_BEDROCK_ENDPOINT_URL=<your_eval_bedrock_endpoint_url>
# EVAL_AWS_ACCESS_KEY_ID=<your_eval_aws_access_key_id>
# EVAL_AWS_SECRET_ACCESS_KEY=<your_eval_aws_secret_access_key>

# EVAL_LLM_PROVIDER=runpod
# EVAL_RUNPOD_ENDPOINT_URL=<your_eval_runpod_endpoint_url>
# EVAL_RUNPOD_API_KEY=<your_eval_runpod_api_key>
# EVAL_RUNPOD_MODEL_ID=<your_eval_runpod_model_id>

SEARCH_MODE=hybrid
MODEL_API_URL=<your_model_api_url>

JUMLAH_SOAL_PRETEST=10
JUMLAH_SOAL_QUIZ_PG=10
JUMLAH_SOAL_QUIZ_ESSAY=5
JUMLAH_SOAL_FLASHCARD=5

# ── Evaluator Node Config ───────────────────────────────────────────────────
# Mengaktifkan/menonaktifkan evaluator node di LangGraph.
# Jika false (default), sistem akan mengabaikan node evaluate dan langsung ke structurer.
EVAL_NODE=false