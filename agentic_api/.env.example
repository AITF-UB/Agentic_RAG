# ==========================================
# BETA AGENTIC API - ENVIRONMENT VARIABLES
# ==========================================

# Security
API_KEY=default-internal-secret-key
ALLOWED_ORIGINS="*"

# Search Strategy Mode (Options: "dense" or "hybrid")
SEARCH_MODE=dense

# Qdrant Vector DB Settings
QDRANT_HOST=76.13.195.1
QDRANT_PORT=6333
QDRANT_TEXT_COLLECTION=Test_pipeline
QDRANT_PIPELINE_EKSTRACTION=test_pipeline

# Model API URL (Target to Model API microservice)
MODEL_API_URL=http://model_api:8003

# Ollama configs (for VLM / image description in pipeline)
OLLAMA_MODEL=qwen2.5vl:7b
OLLAMA_HOST=https://tipoff-errant-chatroom.ngrok-free.dev

# LLM Provider Configuration
# Options: huggingface, bedrock, runpod, tim2_vllm, kaggle_vllm, kaggle_ollama
LLM_PROVIDER=huggingface
MAX_TOKEN=8192
MAX_RAG_TOKEN=4000

# HuggingFace Configs
HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
HF_TOKEN=your_hf_token_here

# AWS Bedrock Configs
BEDROCK_REGION=us-east-1
BEDROCK_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Evaluator Specific LLM (Optional: fallback to LLM_PROVIDER if empty)
EVAL_LLM_PROVIDER=openai
EVAL_OPENAI_API_KEY=your_openai_key
EVAL_OPENAI_MODEL_ID=gpt-4o-mini
